---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact | Swingin' Dance Co."
  description="Contact Swingin' Dance Co. Three Utah Valley venues: The Barn in Provo, Grove Station in Pleasant Grove, and Sparks Museum in West Provo. Questions, private events, and more."
>

  <!-- HERO -->
  <section
    class="relative h-[40vh] min-h-72 flex items-center justify-center text-center"
    style="background-image: url('/images/sdc-wood-floor.jpg'); background-size: cover; background-position: center;"
  >
    <div class="absolute inset-0 bg-dance-dark/80"></div>
    <div class="relative z-10 max-w-2xl mx-auto px-6 pt-20">
      <p class="text-dance-gold font-semibold text-sm tracking-[0.25em] uppercase mb-4">We'd Love to Hear From You</p>
      <h1 class="font-display text-5xl lg:text-6xl font-bold text-dance-cream">Get In Touch</h1>
    </div>
  </section>

  <!-- CONTACT CARDS -->
  <section class="py-24 lg:py-32 bg-dance-dark">
    <div class="max-w-7xl mx-auto px-6">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">

        <!-- The Barn -->
        <div class="bg-dance-mid border border-dance-warm/40 p-8 flex flex-col">
          <div class="w-12 h-12 border border-dance-gold/30 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-dance-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
          </div>
          <p class="text-dance-gold text-xs font-bold tracking-widest uppercase mb-1">Friday Nights</p>
          <h2 class="font-display text-2xl font-bold text-dance-cream mb-5">The Barn</h2>

          <ul class="space-y-4 flex-1">
            <li class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <div>
                <p class="text-dance-text/80">1200 Towne Centre Blvd</p>
                <p class="text-dance-text/80">Suite 1130</p>
                <p class="text-dance-text/80">Provo, UT 84601</p>
                <p class="text-dance-muted text-xs mt-1">Parking available in mall lot</p>
              </div>
            </li>
            <li class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href="tel:8014207489" class="text-dance-text/80 hover:text-dance-gold transition-colors">(801) 420-7489</a>
            </li>
            <li class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <a href="mailto:swingindanceco@gmail.com" class="text-dance-text/80 hover:text-dance-gold transition-colors break-all">swingindanceco@gmail.com</a>
            </li>
          </ul>

          <a href="https://maps.google.com/?q=1200+Towne+Centre+Blvd+Suite+1130+Provo+UT+84601" target="_blank" rel="noopener"
            class="mt-8 py-3 text-center border border-dance-gold/50 text-dance-gold text-xs font-semibold tracking-widest uppercase hover:bg-dance-gold hover:text-dance-dark transition-all duration-200">
            Get Directions
          </a>
        </div>

        <!-- Grove Station -->
        <div class="bg-dance-mid border border-dance-warm/40 p-8 flex flex-col">
          <div class="w-12 h-12 border border-dance-gold/30 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-dance-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <p class="text-dance-gold text-xs font-bold tracking-widest uppercase mb-1">Tuesday Nights</p>
          <h2 class="font-display text-2xl font-bold text-dance-cream mb-5">Grove Station</h2>

          <ul class="space-y-4 flex-1">
            <li class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <div>
                <p class="text-dance-text/80">273 S 2000 W</p>
                <p class="text-dance-text/80">Pleasant Grove, UT 84062</p>
                <p class="text-dance-muted text-xs mt-1">Parking available on-site</p>
              </div>
            </li>
            <li class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href="tel:8016086002" class="text-dance-text/80 hover:text-dance-gold transition-colors">(801) 608-6002</a>
            </li>
            <li class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <a href="mailto:grovestationpg@gmail.com" class="text-dance-text/80 hover:text-dance-gold transition-colors break-all">grovestationpg@gmail.com</a>
            </li>
          </ul>

          <a href="https://maps.google.com/?q=273+S+2000+W+Pleasant+Grove+UT+84062" target="_blank" rel="noopener"
            class="mt-8 py-3 text-center border border-dance-gold/50 text-dance-gold text-xs font-semibold tracking-widest uppercase hover:bg-dance-gold hover:text-dance-dark transition-all duration-200">
            Get Directions
          </a>
        </div>

        <!-- Sparks Museum -->
        <div class="bg-dance-mid border border-dance-warm/40 p-8 flex flex-col">
          <div class="w-12 h-12 border border-dance-gold/30 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-dance-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <p class="text-dance-gold text-xs font-bold tracking-widest uppercase mb-1">Thursday Nights</p>
          <h2 class="font-display text-2xl font-bold text-dance-cream mb-5">Sparks Museum</h2>

          <ul class="space-y-4 flex-1">
            <li class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <div>
                <p class="text-dance-text/80">4134 W Center St</p>
                <p class="text-dance-text/80">Provo, UT 84601</p>
                <p class="text-dance-muted text-xs mt-1">Parking available on-site</p>
              </div>
            </li>
            <li class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href="tel:8014776977" class="text-dance-text/80 hover:text-dance-gold transition-colors">801-477-6977</a>
            </li>
          </ul>

          <a href="https://maps.google.com/?q=4134+W+Center+St+Provo+UT+84601" target="_blank" rel="noopener"
            class="mt-8 py-3 text-center border border-dance-gold/50 text-dance-gold text-xs font-semibold tracking-widest uppercase hover:bg-dance-gold hover:text-dance-dark transition-all duration-200">
            Get Directions
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- PRIVATE EVENTS + SOCIAL -->
  <section class="py-24 bg-dance-mid border-t border-dance-warm/40">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

        <!-- Private Events -->
        <div>
          <p class="text-dance-gold font-semibold text-sm tracking-[0.25em] uppercase mb-3">Book Your Event</p>
          <h2 class="font-display text-3xl font-bold text-dance-cream mb-4">Private Parties &amp; Bands</h2>
          <p class="text-dance-text/70 leading-relaxed mb-6">
            Looking to host a private party or book your band to play at one of our venues? We'd love to make it happen. Reach out and let us know what you have in mind.
          </p>
          <a href="mailto:swingindanceco@gmail.com"
            class="inline-flex items-center gap-2 px-7 py-3 bg-dance-gold text-dance-dark font-bold text-sm tracking-widest uppercase hover:bg-dance-amber transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Send Us a Message
          </a>
        </div>

        <!-- Social -->
        <div>
          <p class="text-dance-gold font-semibold text-sm tracking-[0.25em] uppercase mb-3">Follow Along</p>
          <h2 class="font-display text-3xl font-bold text-dance-cream mb-4">Stay Connected</h2>
          <p class="text-dance-text/70 leading-relaxed mb-8">
            Follow us for schedule updates, event announcements, clips from the floor, and community highlights.
          </p>
          <div class="space-y-4">
            <a href="https://www.tiktok.com/@swingindanceco22" target="_blank" rel="noopener"
              class="flex items-center gap-4 p-4 border border-dance-warm/40 hover:border-dance-gold/40 transition-colors group">
              <div class="w-10 h-10 border border-dance-warm/60 group-hover:border-dance-gold/40 flex items-center justify-center shrink-0 transition-colors">
                <svg class="w-5 h-5 text-dance-muted group-hover:text-dance-gold transition-colors" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/>
                </svg>
              </div>
              <div>
                <p class="text-dance-cream font-semibold text-sm">TikTok</p>
                <p class="text-dance-muted text-xs">@swingindanceco22</p>
              </div>
              <svg class="w-4 h-4 text-dance-muted group-hover:text-dance-gold ml-auto transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>

            <a href="https://www.instagram.com/swingindanceco" target="_blank" rel="noopener"
              class="flex items-center gap-4 p-4 border border-dance-warm/40 hover:border-dance-gold/40 transition-colors group">
              <div class="w-10 h-10 border border-dance-warm/60 group-hover:border-dance-gold/40 flex items-center justify-center shrink-0 transition-colors">
                <svg class="w-5 h-5 text-dance-muted group-hover:text-dance-gold transition-colors" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </div>
              <div>
                <p class="text-dance-cream font-semibold text-sm">Instagram</p>
                <p class="text-dance-muted text-xs">@swingindanceco</p>
              </div>
              <svg class="w-4 h-4 text-dance-muted group-hover:text-dance-gold ml-auto transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>

            <a href="https://www.instagram.com/sdc_logan" target="_blank" rel="noopener"
              class="flex items-center gap-4 p-4 border border-dance-warm/40 hover:border-dance-gold/40 transition-colors group">
              <div class="w-10 h-10 border border-dance-warm/60 group-hover:border-dance-gold/40 flex items-center justify-center shrink-0 transition-colors">
                <svg class="w-5 h-5 text-dance-muted group-hover:text-dance-gold transition-colors" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </div>
              <div>
                <p class="text-dance-cream font-semibold text-sm">Instagram &mdash; Logan</p>
                <p class="text-dance-muted text-xs">@sdc_logan</p>
              </div>
              <svg class="w-4 h-4 text-dance-muted group-hover:text-dance-gold ml-auto transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
