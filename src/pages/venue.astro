---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Dance Venues in Utah Valley | Swingin' Dance Co."
  description="Three country swing dance venues across Utah Valley. The Barn in Provo (Mon & Fri), Grove Station in Pleasant Grove (Tue), and Sparks Museum in West Provo (Thu). $6-$8 admission."
>
  <script type="application/ld+json" slot="schema">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Swingin' Dance Co. Venues",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "DanceGroup",
          "@id": "https://www.swingindanceco.com/venue#the-barn",
          "name": "The Barn - Swingin' Dance Co.",
          "url": "https://www.swingindanceco.com/venue#the-barn",
          "telephone": "+1-801-420-7489",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "1200 Towne Centre Blvd, Suite 1130",
            "addressLocality": "Provo",
            "addressRegion": "UT",
            "postalCode": "84601",
            "addressCountry": "US"
          }
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "DanceGroup",
          "@id": "https://www.swingindanceco.com/venue#grove-station",
          "name": "Grove Station - Swingin' Dance Co.",
          "url": "https://www.swingindanceco.com/venue#grove-station",
          "telephone": "+1-801-608-6002",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "273 S 2000 W",
            "addressLocality": "Pleasant Grove",
            "addressRegion": "UT",
            "postalCode": "84062",
            "addressCountry": "US"
          }
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "DanceGroup",
          "@id": "https://www.swingindanceco.com/venue#sparks-museum",
          "name": "Sparks Museum - Swingin' Dance Co.",
          "url": "https://www.swingindanceco.com/venue#sparks-museum",
          "telephone": "+1-801-477-6977",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "4134 W Center St",
            "addressLocality": "Provo",
            "addressRegion": "UT",
            "postalCode": "84601",
            "addressCountry": "US"
          }
        }
      }
    ]
  }
  </script>

  <!-- HERO -->
  <section
    class="relative h-[40vh] min-h-72 flex items-center justify-center text-center"
    style="background-image: url('/images/sdc-dance-7.jpg'); background-size: cover; background-position: center;"
  >
    <div class="absolute inset-0 bg-dance-dark/62"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 pt-20">
      <p class="text-dance-gold font-semibold text-sm tracking-[0.25em] uppercase mb-4">Where We Dance</p>
      <h1 class="font-display text-5xl lg:text-6xl font-bold text-dance-cream">Three Locations.<br />Three Times the Fun.</h1>
    </div>
  </section>

  <!-- VENUE NAV BAR -->
  <div class="bg-dance-mid border-b border-dance-warm/40 sticky top-16 z-40">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex overflow-x-auto">
        <a href="#the-barn" class="shrink-0 px-6 py-4 text-xs font-semibold tracking-widest uppercase text-dance-gold border-b-2 border-dance-gold hover:text-dance-amber transition-colors">The Barn</a>
        <a href="#grove-station" class="shrink-0 px-6 py-4 text-xs font-semibold tracking-widest uppercase text-dance-text/60 hover:text-dance-gold border-b-2 border-transparent transition-colors">Grove Station</a>
        <a href="#sparks-museum" class="shrink-0 px-6 py-4 text-xs font-semibold tracking-widest uppercase text-dance-text/60 hover:text-dance-gold border-b-2 border-transparent transition-colors">Sparks Museum</a>
      </div>
    </div>
  </div>

  <!-- THE BARN -->
  <section id="the-barn" class="py-24 lg:py-32 bg-dance-dark">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

        <!-- Photos -->
        <div class="grid grid-cols-2 gap-3">
          <img src="/images/sdc-hero.jpg" alt="The Barn dance floor with string lights" class="w-full col-span-2 object-cover" style="height: 300px;" loading="lazy" />
          <img src="/images/sdc-dance-1.jpg" alt="The Barn entrance sign" class="w-full object-cover" style="height: 180px;" loading="lazy" />
          <img src="/images/sdc-dance-11.jpg" alt="The Barn interior with pool tables" class="w-full object-cover" style="height: 180px;" loading="lazy" />
        </div>

        <!-- Info -->
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="w-2 h-8 bg-dance-gold"></span>
            <p class="text-dance-gold font-semibold text-xs tracking-[0.2em] uppercase">Flagship Venue - Mondays &amp; Fridays</p>
          </div>
          <h2 class="font-display text-4xl lg:text-5xl font-bold text-dance-cream mb-2 ml-5">The Barn</h2>
          <p class="text-dance-muted text-sm ml-5 mb-8">Provo Towne Centre Mall, First Floor</p>

          <!-- Schedule -->
          <div class="bg-dance-mid/60 border border-dance-warm/40 p-6 mb-8">
            <h3 class="text-dance-cream font-semibold text-sm tracking-widest uppercase mb-4">Schedule &amp; Admission</h3>
            <div class="space-y-4">
              <div>
                <p class="text-dance-gold text-xs font-bold tracking-widest uppercase mb-2">Monday - Advanced Lessons</p>
                <div class="grid grid-cols-2 gap-2 text-sm">
                  <div class="text-dance-text/80">8:30 PM - 9:15 PM</div>
                  <div class="text-dance-muted">Advanced Lessons</div>
                  <div class="text-dance-text/80">9:15 PM - 10:00 PM</div>
                  <div class="text-dance-muted">Open Swing</div>
                </div>
              </div>
              <div class="border-t border-dance-warm/40 pt-4">
                <p class="text-dance-gold text-xs font-bold tracking-widest uppercase mb-2">Friday - Main Event</p>
                <div class="grid grid-cols-2 gap-2 text-sm">
                  <div class="text-dance-text/80">8:30 PM - 9:00 PM</div>
                  <div class="flex justify-between"><span class="text-dance-muted">Lesson + Dance</span><span class="text-dance-gold font-bold">$6</span></div>
                  <div class="text-dance-text/80">9:00 PM - 1:00 AM</div>
                  <div class="flex justify-between"><span class="text-dance-muted">Open Dance</span><span class="text-dance-gold font-bold">$8</span></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Features -->
          <div class="mb-8">
            <h3 class="text-dance-cream font-semibold text-sm tracking-widest uppercase mb-4">What's Inside</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {[
                'Custom-railed dance floor',
                'Mechanical bull all night',
                'Pool tables',
                'Roping dummies',
                'Restrooms on-site',
                'Water fountains',
              ].map((item) => (
                <li class="flex gap-2 items-center text-dance-text/70 text-sm">
                  <svg class="w-3.5 h-3.5 text-dance-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Address + Map -->
          <div class="border-t border-dance-warm/40 pt-6 space-y-3">
            <div class="flex gap-3 text-sm text-dance-muted">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span>1200 Towne Centre Blvd, Suite 1130, Provo, UT 84601</span>
            </div>
            <div class="flex gap-3 text-sm text-dance-muted">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href="tel:8014207489" class="hover:text-dance-gold transition-colors">(801) 420-7489</a>
            </div>
            <div class="flex gap-3 text-sm text-dance-muted">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <a href="mailto:swingindanceco@gmail.com" class="hover:text-dance-gold transition-colors">swingindanceco@gmail.com</a>
            </div>
          </div>

          <a href="https://maps.google.com/?q=1200+Towne+Centre+Blvd+Suite+1130+Provo+UT+84601" target="_blank" rel="noopener"
            class="mt-6 inline-flex items-center gap-2 px-6 py-3 bg-dance-gold text-dance-dark font-bold text-sm tracking-widest uppercase hover:bg-dance-amber transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
            Get Directions
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- GROVE STATION -->
  <section id="grove-station" class="py-24 lg:py-32 bg-dance-mid">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

        <!-- Info first on desktop -->
        <div class="order-2 lg:order-1">
          <div class="flex items-center gap-3 mb-2">
            <span class="w-2 h-8 bg-dance-gold"></span>
            <p class="text-dance-gold font-semibold text-xs tracking-[0.2em] uppercase">Tuesday Nights - Pleasant Grove</p>
          </div>
          <h2 class="font-display text-4xl lg:text-5xl font-bold text-dance-cream mb-2 ml-5">Grove Station</h2>
          <p class="text-dance-muted text-sm ml-5 mb-8">273 S 2000 W, Pleasant Grove</p>

          <!-- Schedule -->
          <div class="bg-dance-dark/40 border border-dance-warm/40 p-6 mb-8">
            <h3 class="text-dance-cream font-semibold text-sm tracking-widest uppercase mb-4">Schedule &amp; Admission</h3>
            <div class="space-y-2">
              <div class="grid grid-cols-2 gap-2 text-sm">
                <div class="text-dance-text/80">8:30 PM - 9:00 PM</div>
                <div class="flex justify-between"><span class="text-dance-muted">Lesson + Dance</span><span class="text-dance-gold font-bold">$6</span></div>
                <div class="text-dance-text/80">9:00 PM - Midnight</div>
                <div class="flex justify-between"><span class="text-dance-muted">Open Dance</span><span class="text-dance-gold font-bold">$8</span></div>
              </div>
            </div>
          </div>

          <!-- Features -->
          <div class="mb-8">
            <h3 class="text-dance-cream font-semibold text-sm tracking-widest uppercase mb-4">What's Inside</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {[
                'Gorgeous spacious indoor space',
                'High ceilings',
                'Tables and chairs',
                'Soda shop on-site',
                'Entry hall with private room',
                'Restrooms on-site',
              ].map((item) => (
                <li class="flex gap-2 items-center text-dance-text/70 text-sm">
                  <svg class="w-3.5 h-3.5 text-dance-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Contact -->
          <div class="border-t border-dance-warm/40 pt-6 space-y-3">
            <div class="flex gap-3 text-sm text-dance-muted">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span>273 S 2000 W, Pleasant Grove, UT 84062</span>
            </div>
            <div class="flex gap-3 text-sm text-dance-muted">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href="tel:8016086002" class="hover:text-dance-gold transition-colors">(801) 608-6002</a>
            </div>
            <div class="flex gap-3 text-sm text-dance-muted">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <a href="mailto:grovestationpg@gmail.com" class="hover:text-dance-gold transition-colors">grovestationpg@gmail.com</a>
            </div>
          </div>

          <a href="https://maps.google.com/?q=273+S+2000+W+Pleasant+Grove+UT+84062" target="_blank" rel="noopener"
            class="mt-6 inline-flex items-center gap-2 px-6 py-3 bg-dance-gold text-dance-dark font-bold text-sm tracking-widest uppercase hover:bg-dance-amber transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
            Get Directions
          </a>
        </div>

        <!-- Photos -->
        <div class="order-1 lg:order-2 grid grid-cols-2 gap-3">
          <img src="/images/grove-hero.webp" alt="Grove Station exterior, Pleasant Grove" class="w-full col-span-2 object-cover" style="height: 280px;" loading="lazy" />
          <img src="/images/grove-2.jpg" alt="Grove Station interior with draped ceiling and string lights" class="w-full object-cover" style="height: 200px;" loading="lazy" />
          <img src="/images/grove-3.jpg" alt="Packed dance floor at Grove Station on a Tuesday night" class="w-full object-cover" style="height: 200px;" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- SPARKS MUSEUM -->
  <section id="sparks-museum" class="py-24 lg:py-32 bg-dance-dark">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

        <!-- Photos -->
        <div class="grid grid-cols-2 gap-3">
          <img src="/images/sparks-3.jpg" alt="Sparks Museum exterior with Sinclair signs at sunset" class="w-full col-span-2 object-cover" style="height: 280px;" loading="lazy" />
          <img src="/images/sparks-2.jpg" alt="Sparks Museum interior packed with dancers and vintage signs" class="w-full object-cover" style="height: 200px;" loading="lazy" />
          <img src="/images/sparks-4.jpg" alt="Dancing at Sparks Museum under Keystone and Mobile gasoline signs" class="w-full object-cover" style="height: 200px;" loading="lazy" />
        </div>

        <!-- Info -->
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="w-2 h-8 bg-dance-gold"></span>
            <p class="text-dance-gold font-semibold text-xs tracking-[0.2em] uppercase">Thursday Nights - West Provo</p>
          </div>
          <h2 class="font-display text-4xl lg:text-5xl font-bold text-dance-cream mb-2 ml-5">Sparks Museum</h2>
          <p class="text-dance-muted text-sm ml-5 mb-8">4134 W Center St, Provo</p>

          <!-- Schedule -->
          <div class="bg-dance-mid/60 border border-dance-warm/40 p-6 mb-8">
            <h3 class="text-dance-cream font-semibold text-sm tracking-widest uppercase mb-4">Schedule &amp; Admission</h3>
            <div class="space-y-2">
              <div class="grid grid-cols-2 gap-2 text-sm">
                <div class="text-dance-text/80">8:30 PM - 9:00 PM</div>
                <div class="flex justify-between"><span class="text-dance-muted">Lesson + Dance</span><span class="text-dance-gold font-bold">$6</span></div>
                <div class="text-dance-text/80">9:00 PM - Midnight</div>
                <div class="flex justify-between"><span class="text-dance-muted">Open Dance</span><span class="text-dance-gold font-bold">$8</span></div>
              </div>
            </div>
          </div>

          <!-- Features -->
          <div class="mb-8">
            <h3 class="text-dance-cream font-semibold text-sm tracking-widest uppercase mb-4">About This Venue</h3>
            <p class="text-dance-text/70 text-sm leading-relaxed mb-4">
              An affordable, flexible space ideal for community gatherings, corporate events, and celebrations. Sparks Museum brings an eclectic energy to Thursday nights in Utah County.
            </p>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {[
                'Corporate event-friendly space',
                'Community gathering venue',
                'Affordable admission',
                'Parking available on-site',
              ].map((item) => (
                <li class="flex gap-2 items-center text-dance-text/70 text-sm">
                  <svg class="w-3.5 h-3.5 text-dance-gold shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Contact -->
          <div class="border-t border-dance-warm/40 pt-6 space-y-3">
            <div class="flex gap-3 text-sm text-dance-muted">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span>4134 W Center St, Provo, UT 84601</span>
            </div>
            <div class="flex gap-3 text-sm text-dance-muted">
              <svg class="w-4 h-4 text-dance-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href="tel:8014776977" class="hover:text-dance-gold transition-colors">801-477-6977</a>
            </div>
          </div>

          <a href="https://maps.google.com/?q=4134+W+Center+St+Provo+UT+84601" target="_blank" rel="noopener"
            class="mt-6 inline-flex items-center gap-2 px-6 py-3 bg-dance-gold text-dance-dark font-bold text-sm tracking-widest uppercase hover:bg-dance-amber transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
            Get Directions
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-dance-mid border-t border-dance-warm/40 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-display text-3xl lg:text-4xl font-bold text-dance-cream mb-4">Ready to Dance?</h2>
      <p class="text-dance-text/70 mb-8">No experience needed. Show up, learn the moves, and see you on the floor.</p>
      <a href="/contact"
        class="inline-block px-10 py-4 bg-dance-gold text-dance-dark font-bold text-sm tracking-widest uppercase hover:bg-dance-amber transition-colors">
        Contact Us
      </a>
    </div>
  </section>

</Layout>
