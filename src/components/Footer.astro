        <ul class="space-y-3 text-sm text-dance-muted">
          <li class="flex gap-2">
            <svg class="w-4 h-4 mt-0.5 text-dance-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>1200 Towne Centre Blvd, Suite 1130<br />Provo, UT 84601</span>
          </li>
          <li class="flex gap-2">
            <svg class="w-4 h-4 mt-0.5 text-dance-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:8014207489" class="hover:text-dance-gold transition-colors">(801) 420-7489</a>
          </li>
          <li class="flex gap-2">
            <svg class="w-4 h-4 mt-0.5 text-dance-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:swingindanceco@gmail.com" class="hover:text-dance-gold transition-colors">swingindanceco@gmail.com</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-dance-warm/40 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-dance-muted text-xs">&copy; 2025 Swingin' Dance Co. All rights reserved.</p>
      <p class="text-dance-muted text-xs">
        Built by <a href="https://3trmedia.com" target="_blank" rel="noopener" class="text-dance-gold hover:text-dance-amber transition-colors">3TR Media</a>
      </p>
    </div>
