---

<footer class="bg-dance-mid border-t border-dance-warm/40">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/sdc-logo.png" alt="Swingin' Dance Co." class="h-10 w-auto" />
          <span class="font-display text-dance-cream font-semibold text-lg">Swingin' Dance Co.</span>
        </div>
        <p class="text-dance-muted text-sm leading-relaxed max-w-xs">
          Bringing the community together through country swing dancing. Three nights a week across Utah Valley.
        </p>
        <div class="flex gap-4 mt-5">
          <a href="https://www.tiktok.com/@swingindanceco22" target="_blank" rel="noopener" aria-label="TikTok"
            class="text-dance-muted hover:text-dance-gold transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/swingindanceco" target="_blank" rel="noopener" aria-label="Instagram"
            class="text-dance-muted hover:text-dance-gold transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-dance-cream font-semibold text-sm tracking-widest uppercase mb-5">Quick Links</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-dance-muted hover:text-dance-gold text-sm transition-colors">Home</a></li>
          <li><a href="/venue" class="text-dance-muted hover:text-dance-gold text-sm transition-colors">Venues</a></li>
          <li><a href="/contact" class="text-dance-muted hover:text-dance-gold text-sm transition-colors">Contact</a></li>
          <li><a href="https://www.swinginmechanicalbulls.com/" target="_blank" rel="noopener" class="text-dance-muted hover:text-dance-gold text-sm transition-colors">Swingin' Mechanical Bulls</a></li>
          <li><a href="https://www.westerneventscenter.com/" target="_blank" rel="noopener" class="text-dance-muted hover:text-dance-gold text-sm transition-colors">Western Events Center</a></li>
        </ul>
