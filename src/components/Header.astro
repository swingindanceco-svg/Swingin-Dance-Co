---
const pathname = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/' ? pathname === '/' : pathname.startsWith(path);
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-dance-dark border-b border-dance-warm/30">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-16 lg:h-18">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0">
      <img src="/images/sdc-logo.png" alt="Swingin' Dance Co." class="h-9 w-auto" />
      <span class="font-display text-dance-cream font-semibold text-lg hidden sm:block tracking-wide">
        Swingin' Dance Co.
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-1">
      <a href="/"
        class={`px-4 py-2 text-sm font-semibold tracking-widest uppercase transition-colors duration-200 ${isActive('/') ? 'text-dance-gold' : 'text-dance-text/80 hover:text-dance-cream'}`}>
        Home
      </a>
      <a href="/venue"
        class={`px-4 py-2 text-sm font-semibold tracking-widest uppercase transition-colors duration-200 ${isActive('/venue') ? 'text-dance-gold' : 'text-dance-text/80 hover:text-dance-cream'}`}>
        Venues
      </a>
      <a href="https://www.swinginmechanicalbulls.com/" target="_blank" rel="noopener"
        class="px-4 py-2 text-sm font-semibold tracking-widest uppercase text-dance-text/80 hover:text-dance-cream transition-colors duration-200">
        The Bull
      </a>
      <a href="/contact"
        class={`px-4 py-2 text-sm font-semibold tracking-widest uppercase transition-colors duration-200 ${isActive('/contact') ? 'text-dance-gold' : 'text-dance-text/80 hover:text-dance-cream'}`}>
        Contact
      </a>
      <a href="https://www.westerneventscenter.com/" target="_blank" rel="noopener"
        class="ml-3 px-5 py-2 border border-dance-gold text-dance-gold text-sm font-semibold tracking-widest uppercase hover:bg-dance-gold hover:text-dance-dark transition-all duration-200">
        Rent the Barn
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" aria-label="Open menu" class="lg:hidden text-dance-cream p-2">
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-menu" class="hidden lg:hidden bg-dance-mid border-t border-dance-warm">
    <div class="flex flex-col px-6 py-4 gap-1">
      <a href="/" class={`py-3 text-sm font-semibold tracking-widest uppercase border-b border-dance-warm/40 ${isActive('/') ? 'text-dance-gold' : 'text-dance-text/80'}`}>Home</a>
      <a href="/venue" class={`py-3 text-sm font-semibold tracking-widest uppercase border-b border-dance-warm/40 ${isActive('/venue') ? 'text-dance-gold' : 'text-dance-text/80'}`}>Venues</a>
      <a href="https://www.swinginmechanicalbulls.com/" target="_blank" rel="noopener" class="py-3 text-sm font-semibold tracking-widest uppercase border-b border-dance-warm/40 text-dance-text/80">The Bull</a>
      <a href="/contact" class={`py-3 text-sm font-semibold tracking-widest uppercase border-b border-dance-warm/40 ${isActive('/contact') ? 'text-dance-gold' : 'text-dance-text/80'}`}>Contact</a>
      <a href="https://www.westerneventscenter.com/" target="_blank" rel="noopener" class="mt-3 py-3 text-center border border-dance-gold text-dance-gold text-sm font-semibold tracking-widest uppercase">Rent the Barn</a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });
</script>
