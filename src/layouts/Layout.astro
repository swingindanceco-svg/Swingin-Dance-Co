---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/images/sdc-hero.jpg',
  ogType = 'website',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />

    <ClientRouter />

    <!-- Preload slot for per-page LCP image hints -->
    <slot name="preload" />

    <!-- JSON-LD: default Organization — pages can inject additional schema via this slot -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Swingin' Dance Co.",
      "url": "https://www.swingindanceco.com",
      "logo": "https://www.swingindanceco.com/images/sdc-logo.png",
      "telephone": "+1-801-420-7489",
      "email": "swingindanceco@gmail.com",
      "sameAs": [
        "https://www.instagram.com/swingindanceco",
        "https://www.tiktok.com/@swingindanceco22"
      ]
    }
    </script>
    <slot name="schema" />

    <!-- Favicon -->
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Barlow:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics -->
    <!-- GA tag goes here once account is set up -->
  </head>
  <body class="bg-dance-dark text-dance-text font-body antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
